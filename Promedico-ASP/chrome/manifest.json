{
  "manifest_version": 3,
  "name": "Promedico ASP Helper",
  "version": "2.0.2",
  "description": "Automation scripts for Promedico ASP",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "clipboardWrite",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.promedico-asp.nl/*",
    "https://www.zorgdomein.nl/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icons/icon-48.png",
    "default_title": "Promedico ASP Helper",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.promedico-asp.nl/promedico/*",
        "https://www.zorgdomein.nl/*",
        "https://www.zneller.nl/*"
      ],
      "js": [
        "config.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "scripts/*.js",
        "config.js",
        "profiles.js",
        "storage-bridge-client.js",
        "zorgdomein-menus/*.js"
      ],
      "matches": [
        "https://www.promedico-asp.nl/*",
        "https://www.zorgdomein.nl/*",
        "https://www.zneller.nl/*"
      ]
    }
  ]
}